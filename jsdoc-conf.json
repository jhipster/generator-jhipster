{
  "tags": {
    "allowUnknownTags": true
  },
  "source": {
    "include": [
      "dist/generators/app/cleanup.js",
      "dist/generators/base-workspaces/internal/docker-base.js",
      "dist/generators/base-workspaces/internal/docker-prompts.js",
      "dist/generators/base/generator.js",
      "dist/generators/base-core/generator.js",
      "dist/generators/generator-constants.js",
      "dist/lib/utils/index.js"
    ]
  },
  "plugins": [],
  "templates": {
    "cleverLinks": true,
    "monospaceLinks": true,
    "default": {
      "outputSourceFiles": true
    }
  },
  "opts": {
    "recurse": true,
    "destination": "./docs/",
    "readme": "README.md"
  }
}
