# Prettier configuration

printWidth: 140
singleQuote: true
tabWidth: <%= prettierTabWidth %>
useTabs: false

# js and ts rules:
arrowParens: avoid

# jsx and tsx rules:
bracketSameLine: false

<%_ if (backendTypeJavaAny || !monorepository) { _%>
plugins:
  <%_ if (!monorepository) { _%>
  - prettier-plugin-packagejson
  <%_ } _%>
<%_ } _%>
<%_ if (backendTypeJavaAny) { _%>
  - prettier-plugin-java

# java rules:
overrides:
  - files: "*.java"
    options:
      tabWidth: 4
<%_ } _%>
