<%_ const fieldsWithDocumentation = fields.filter(field => field.documentation); _%>
{
    "<%- frontendAppName %>": {
        "<%- entityTranslationKey %>" : {
            "home": {
                "title": "<%- entityNamePluralHumanized %>",
                "refreshListLabel": "Refresh list",
<%_ if (!readOnly) { _%>
                "createLabel": "Creeare o nouă entitate <%- entityNameHumanized %>",
                "createOrEditLabel": "Creeare sau editare <%- entityNameHumanized %>",
<%_ } _%>
<%_ if (locals.searchEngineAny) { _%>
                "search": "Căutare după <%- entityNameHumanized %>",
<%_ } _%>
                "notFound": "No <%- entityNamePluralHumanized %> found"
            },
<%_ if (!microserviceAppName && !readOnly) { _%>
            "created": "A fost creată o nouă entitate <%- entityNameHumanized %> cu identificatorul {{ param }}",
            "updated": "<%- entityNameHumanized %> cu identificatorul {{ param }} a fost actualizată",
            "deleted": "<%- entityNameHumanized %> cu identificatorul {{ param }} a fost ștearsă",
<%_ } _%>
<%_ if (!readOnly) { _%>
            "delete": {
                "question": "Sunteți sigur că doriți să ștergeți <%- entityNameHumanized %> {{ id }}?"
            },
<%_ } _%>
            "detail": {
                "title": "<%- entityNameHumanized %>"
            }
<%_ for (const field of fields) { _%>,
            "<%- field.fieldName %>": "<%- field.fieldNameHumanized %>"
<%_ } _%>
<%_ for (const relationship of relationships) { _%>,
            "<%- relationship.relationshipName %>": "<%- relationship.relationshipNameHumanized %>"
<%_ } _%>
<%_ if (fieldsWithDocumentation.length > 0) { _%>,
            "help": {
  <%_ for (const [key, field] of Object.entries(fieldsWithDocumentation)) { _%>
                "<%- field.fieldName %>": "<%- field.documentation %>"<% if (key < fieldsWithDocumentation.length - 1) { %>,<% } %>
  <%_ } _%>
            }
<%_ } _%>
        }
    }
<%_ if (microserviceAppName && !readOnly) { _%>,
    "<%- microserviceAppName %>": {
        "<%- entityTranslationKey %>" : {
            "created": "A fost creată o nouă entitate <%- entityNameHumanized %> cu identificatorul {{ param }}",
            "updated": "Entitatea <%- entityNameHumanized %> cu identificatorul {{ param }} a fost actualizată",
            "deleted": "Entitatea <%- entityNameHumanized %> cu identificatorul {{ param }} a fost ștearsă"
        }
    }
<%_ } _%>
}
