<%_ const fieldsWithDocumentation = fields.filter(field => field.documentation); _%>
{
    "<%- frontendAppName %>": {
        "<%- entityTranslationKey %>" : {
            "home": {
                "title": "<%- entityNamePluralHumanized %>",
                "refreshListLabel": "Refresh list",
<%_ if (!readOnly) { _%>
                "createLabel": "Krijo një të ri <%- entityNameHumanized %>",
                "createOrEditLabel": "Krijo ose përpuno një <%- entityNameHumanized %>",
<%_ } _%>
<%_ if (locals.searchEngineAny) { _%>
                "search": "Kërko për <%- entityNameHumanized %>",
<%_ } _%>
                "notFound": "No <%- entityNamePluralHumanized %> found"
            },
<%_ if (!microserviceAppName && !readOnly) { _%>
            "created": "Një <%- entityNameHumanized %> i ri u krijua me identifikues {{ param }}",
            "updated": "Një <%- entityNameHumanized %> u përpunua me identifikues {{ param }}",
            "deleted": "Një <%- entityNameHumanized %> u fshi me identifikues {{ param }}",
<%_ } _%>
<%_ if (!readOnly) { _%>
            "delete": {
                "question": "Jeni i sigurtë që doni të fshini <%- entityNameHumanized %> {{ id }}?"
            },
<%_ } _%>
            "detail": {
                "title": "<%- entityNameHumanized %>"
            }
<%_ for (const field of fields) { _%>,
            "<%- field.fieldName %>": "<%- field.fieldNameHumanized %>"
<%_ } _%>
<%_ for (const relationship of relationships) { _%>,
            "<%- relationship.relationshipName %>": "<%- relationship.relationshipNameHumanized %>"
<%_ } _%>
<%_ if (fieldsWithDocumentation.length > 0) { _%>,
            "help": {
  <%_ for (const [key, field] of Object.entries(fieldsWithDocumentation)) { _%>
                "<%- field.fieldName %>": "<%- field.documentation %>"<% if (key < fieldsWithDocumentation.length - 1) { %>,<% } %>
  <%_ } _%>
            }
<%_ } _%>
        }
    }
<%_ if (microserviceAppName && !readOnly) { _%>,
    "<%- microserviceAppName %>": {
        "<%- entityTranslationKey %>" : {
            "created": "Një <%- entityNameHumanized %> i ri u krijua me identifikues {{ param }}",
            "updated": "Një <%- entityNameHumanized %> u përpunua me identifikues {{ param }}",
            "deleted": "Një <%- entityNameHumanized %> u fshi me identifikues {{ param }}"
        }
    }
<%_ } _%>
}
