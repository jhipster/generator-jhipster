<%_ const fieldsWithDocumentation = fields.filter(field => field.documentation); _%>
{
    "<%- frontendAppName %>": {
        "<%- entityTranslationKey %>" : {
            "home": {
                "title": "<%- entityNamePluralHumanized %>",
                "refreshListLabel": "ਸੂਚੀ ਤਾਜ਼ਾ ਕਰੋ",
<%_ if (!readOnly) { _%>
                "createLabel": "ਇੱਕ ਨਵਾਂ <%- entityNameHumanized %> ਬਣਾਓ",
                "createOrEditLabel": "ਇੱਕ <%- entityNameHumanized %> ਬਣਾਓ ਜਾਂ ਸੰਪਾਦਿਤ ਕਰੋ",
<%_ } _%>
<%_ if (locals.searchEngineAny) { _%>
                "search": "<%- entityNameHumanized %> ਲਈ ਖੋਜ",
<%_ } _%>
                "notFound": "ਕੋਈ <%- entityNamePluralHumanized %> ਨਹੀਂ ਮਿਲਿਆ"
            },
<%_ if (!microserviceAppName && !readOnly) { _%>
            "created": "ਇੱਕ ਨਵਾਂ <%- entityNameHumanized %> ਪਛਾਣਕਰਤਾ {{ param }} ਨਾਲ ਬਣਾਇਆ ਗਿਆ ਹੈ",
            "updated": "ਇੱਕ <%- entityNameHumanized %> ਪਛਾਣਕਰਤਾ {{ param }} ਨਾਲ ਅਪਡੇਟ ਕੀਤਾ ਗਿਆ ਹੈ",
            "deleted": "ਇੱਕ <%- entityNameHumanized %> ਪਛਾਣਕਰਤਾ {{ param }} ਨਾਲ ਮਿਟਾ ਦਿੱਤਾ ਗਿਆ ਹੈ",
<%_ } _%>
<%_ if (!readOnly) { _%>
            "delete": {
                "question": "ਕੀ ਤੁਸੀਂ ਨਿਸ਼ਚਤ ਰੂਪ ਤੋਂ <%- entityNameHumanized %> {{ id }} ਨੂੰ ਮਿਟਾਉਣਾ ਚਾਹੁੰਦੇ ਹੋ?"
            },
<%_ } _%>
            "detail": {
                "title": "<%- entityNameHumanized %>"
            }
<%_ for (const field of fields) { _%>,
            "<%- field.fieldName %>": "<%- field.fieldNameHumanized %>"
<%_ } _%>
<%_ for (const relationship of relationships) { _%>,
            "<%- relationship.relationshipName %>": "<%- relationship.relationshipNameHumanized %>"
<%_ } _%>
<%_ if (fieldsWithDocumentation.length > 0) { _%>,
            "help": {
  <%_ for (const [key, field] of Object.entries(fieldsWithDocumentation)) { _%>
                "<%- field.fieldName %>": "<%- field.documentation %>"<% if (key < fieldsWithDocumentation.length - 1) { %>,<% } %>
  <%_ } _%>
            }
<%_ } _%>
        }
    }
<%_ if (microserviceAppName && !readOnly) { _%>,
    "<%- microserviceAppName %>": {
        "<%- entityTranslationKey %>" : {
            "created": "ਇੱਕ ਨਵਾਂ <%- entityNameHumanized %> ਪਛਾਣਕਰਤਾ {{ param }} ਨਾਲ ਬਣਾਇਆ ਗਿਆ ਹੈ",
            "updated": "ਇੱਕ <%- entityNameHumanized %> ਪਛਾਣਕਰਤਾ {{ param }} ਨਾਲ ਅਪਡੇਟ ਕੀਤਾ ਗਿਆ ਹੈ",
            "deleted": "ਇੱਕ <%- entityNameHumanized %> ਪਛਾਣਕਰਤਾ {{ param }} ਨਾਲ ਮਿਟਾ ਦਿੱਤਾ ਗਿਆ ਹੈ"
        }
    }
<%_ } _%>
}
