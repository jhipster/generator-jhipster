-%><% let helpBlocks = 0; %>
{
    "<%- frontendAppName %>": {
        "<%- entityTranslationKey %>" : {
            "home": {
                "title": "<%- entityNamePluralHumanized %>",
                "refreshListLabel": "Siyahını yenilə",
<%_ if (!readOnly) { _%>
                "createLabel": "Yeni <%- entityNameHumanized %> əlavə et",
                "createOrEditLabel": "Yeni <%- entityNameHumanized %> əlavə et və ya yenilə",
<%_ } _%>
<%_ if (locals.searchEngineAny) { _%>
                "search": "<%- entityNameHumanized %> axtar",
<%_ } _%>
                "notFound": "<%- entityNamePluralHumanized %> məlumatı tapılmadı"
            },
<%_ if (!microserviceAppName && !readOnly) { _%>
            "created": "{{ param }} ID ilə bir <%- entityNameHumanized %> əlavə edildi",
            "updated": "{{ param }} nolu <%- entityNameHumanized %> dəyişildi",
            "deleted": "{{ param }} nolu <%- entityNameHumanized %> silindi",
<%_ } _%>
<%_ if (!readOnly) { _%>
            "delete": {
                "question": "{{ id }} nolu <%- entityNameHumanized %> silinəcək. Davam etmək istəyirsiniz?"
            },
<%_ } _%>
            "detail": {
                "title": "<%- entityNameHumanized %>"
            }<% for (const field of fields) {
            if (typeof field.documentation !== 'undefined') ++helpBlocks; %>,
            "<%- field.fieldName %>": "<%- field.fieldNameHumanized %>"<% } %><% for (const relationship of relationships) { %>,
            "<%- relationship.relationshipName %>": "<%- relationship.relationshipNameHumanized %>"<% } if (helpBlocks > 0) { %>,
            "help": {<% for (const field of fields) {
                if (field.documentation) {
                    --helpBlocks; %>
                "<%- field.fieldName %>": "<%- field.documentation %>"<% if (helpBlocks > 0) { %>,<% }
                }
            } %>
            }<% } %>
        }
    }
<%_ if (microserviceAppName && !readOnly) { _%>,
    "<%- microserviceAppName %>": {
        "<%- entityTranslationKey %>" : {
            "created": "{{ param }} ID ilə bir <%- entityNameHumanized %> əlavə edildi",
            "updated": "{{ param }} nolu <%- entityNameHumanized %> dəyişdirildi",
            "deleted": "{{ param }} nolu <%- entityNameHumanized %> silindi"
        }
    }
<%_ } _%>
}
