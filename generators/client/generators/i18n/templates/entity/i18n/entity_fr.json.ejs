-%><% let helpBlocks = 0; %>
{
    "<%- frontendAppName %>": {
        "<%- entityTranslationKey %>" : {
            "home": {
                "title": "<%- entityClassPlural %>",
                "refreshListLabel": "Actualiser la liste",
<%_ if (!readOnly) { _%>
                "createLabel": "Créer un nouveau <%- entityNameHumanized %>",
                "createOrEditLabel": "Créer ou éditer un <%- entityNameHumanized %>",
<%_ } _%>
<%_ if (locals.searchEngineAny) { _%>
                "search": "Recherche pour <%- entityNameHumanized %>",
<%_ } _%>
                "notFound": "Aucun <%- entityNameHumanized %> trouvé"
            },
<%_ if (!microserviceAppName && !readOnly) { _%>
            "created": "Un nouveau <%- entityNameHumanized %> a été créé avec l'identifiant {{ param }}",
            "updated": "Le <%- entityNameHumanized %> avec l'identifiant {{ param }} a été mis à jour",
            "deleted": "Le <%- entityNameHumanized %> avec l'identifiant {{ param }} a été supprimé",
<%_ } _%>
<%_ if (!readOnly) { _%>
            "delete": {
                "question": "Êtes-vous certain de vouloir supprimer le <%- entityNameHumanized %> {{ id }} ?"
            },
<%_ } _%>
            "detail": {
                "title": "<%- entityNameHumanized %>"
            }<% for (const field of fields) {
            if (typeof field.documentation !== 'undefined') ++helpBlocks; %>,
            "<%- field.fieldName %>": "<%- field.fieldNameHumanized %>"<% } %><% for (const relationship of relationships) { %>,
            "<%- relationship.relationshipName %>": "<%- relationship.relationshipNameHumanized %>"<% } if (helpBlocks > 0) { %>,
            "help": {<% for (const field of fields) {
                if (field.documentation) {
                    --helpBlocks; %>
                "<%- field.fieldName %>": "<%- field.documentation %>"<% if (helpBlocks > 0) { %>,<% }
                }
            } %>
            }<% } %>
        }
    }
<%_ if (microserviceAppName && !readOnly) { _%>,
    "<%- microserviceAppName %>": {
        "<%- entityTranslationKey %>" : {
            "created": "Un nouveau <%- entityNameHumanized %> a été créé avec l'identifiant {{ param }}",
            "updated": "Le <%- entityNameHumanized %> avec l'identifiant {{ param }} a été mis à jour",
            "deleted": "Le <%- entityNameHumanized %> avec l'identifiant {{ param }} a été supprimé"
        }
    }
<%_ } _%>
}
