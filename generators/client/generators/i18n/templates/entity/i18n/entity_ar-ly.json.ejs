<%_ let helpBlocks = 0; _%>
{
    "<%- frontendAppName %>": {
        "<%- entityTranslationKey %>" : {
            "home": {
                "title": "<%- entityNamePluralHumanized %>",
                "refreshListLabel": "تحديث القائمة",
<%_ if (!readOnly) { _%>
                "createLabel": "إنشاء <%- entityNameHumanized %> جديد",
                "createOrEditLabel": "إنشاء أو تعديل <%- entityNameHumanized %>",
<%_ } _%>
<%_ if (locals.searchEngineAny) { _%>
                "search": "البحث عن <%- entityNameHumanized %>",
<%_ } _%>
                "notFound": "لم يتم العثور على <%- entityNamePluralHumanized %>"
            },
<%_ if (!microserviceAppName && !readOnly) { _%>
            "created": "<%- entityNameHumanized %> جديد تم إنشاؤه بالمعرف {{ param }}",
            "updated": "<%- entityNameHumanized %> تم تحديثه بالمعرف {{ param }}",
            "deleted": "<%- entityNameHumanized %> تم حذفه بالمعرف {{ param }}",
<%_ } _%>
<%_ if (!readOnly) { _%>
            "delete": {
                "question": "هل أنت متأكد أنك تريد حذف <%- entityNameHumanized %> {{ id }}؟"
            },
<%_ } _%>
            "detail": {
                "title": "<%- entityNameHumanized %>"
            }<% for (const field of fields) {
            if (typeof field.documentation !== 'undefined') ++helpBlocks; %>,
            "<%- field.fieldName %>": "<%- field.fieldNameHumanized %>"<% } %><% for (const relationship of relationships) { %>,
            "<%- relationship.relationshipName %>": "<%- relationship.relationshipNameHumanized %>"<% } if (helpBlocks > 0) { %>,
            "help": {<% for (const field of fields) {
                if (field.documentation) {
                    --helpBlocks; %>
                "<%- field.fieldName %>": "<%- field.documentation %>"<% if (helpBlocks > 0) { %>,<% }
                }
            } %>
            }<% } %>
        }
    }
<%_ if (microserviceAppName && !readOnly) { _%>,
    "<%- microserviceAppName %>": {
        "<%- entityTranslationKey %>" : {
            "created": "<%- entityNameHumanized %> جديد تم إنشاؤه بالمعرف {{ param }}",
            "updated": "<%- entityNameHumanized %> تم تحديثه بالمعرف {{ param }}",
            "deleted": "<%- entityNameHumanized %> تم حذفه بالمعرف {{ param }}"
        }
    }
<%_ } _%>
}
