<%_ const fieldsWithDocumentation = fields.filter(field => field.documentation); _%>
{
<%_ /* Male (default) variant */
    let Um = 'Um';
    let novo = 'novo';
    let criado = 'criado';
    let atualizado = 'atualizado';
    let excluido = 'excluído';
    let Nenhum = 'Nenhum';
    let encontrado = 'encontrado';
_%>
<%_ if (entityI18nVariant === 'female') { _%>
  <%_ Um = 'Uma';
        novo = 'nova';
        criado = 'criada';
        atualizado = 'atualizada';
        excluido = 'excluída';
        Nenhum = 'Nenhuma';
        encontrado = 'encontrada';
  _%>
<%_ } _%>
    "<%- frontendAppName %>": {
        "<%- entityTranslationKey %>" : {
            "home": {
                "title": "<%- entityNamePluralHumanized %>",
                "refreshListLabel": "Atualizar lista",
<%_ if (!readOnly) { _%>
                "createLabel": "Criar <%- novo %> <%- entityNameHumanized %>",
                "createOrEditLabel": "Criar ou editar <%- entityNameHumanized %>",
<%_ } _%>
<%_ if (locals.searchEngineAny) { _%>
                "search": "Pesquisar por <%- entityNameHumanized %>",
<%_ } _%>
                "notFound": "<%- Nenhum %> <%- entityNameHumanized %> <%- encontrado %>"
            },
<%_ if (!microserviceAppName && !readOnly) { _%>
            "created": "<%- Um %> <%- novo %> <%- entityNameHumanized %> foi <%- criado %> com o identificador {{ param }}",
            "updated": "<%- Um %> <%- entityNameHumanized %> foi <%- atualizado %> com o identificador {{ param }}",
            "deleted": "<%- Um %> <%- entityNameHumanized %> foi <%- excluido %> com o identificador {{ param }}",
<%_ } _%>
<%_ if (!readOnly) { _%>
            "delete": {
                "question": "Tem certeza de que deseja excluir <%- entityNameHumanized %> {{ id }}?"
            },
<%_ } _%>
            "detail": {
                "title": "<%- entityNameHumanized %>"
            }
<%_ for (const field of fields) { _%>,
            "<%- field.fieldName %>": "<%- field.fieldNameHumanized %>"
<%_ } _%>
<%_ for (const relationship of relationships) { _%>,
            "<%- relationship.relationshipName %>": "<%- relationship.relationshipNameHumanized %>"
<%_ } _%>
<%_ if (fieldsWithDocumentation.length > 0) { _%>,
            "help": {
  <%_ for (const [key, field] of Object.entries(fieldsWithDocumentation)) { _%>
                "<%- field.fieldName %>": "<%- field.documentation %>"<% if (key < fieldsWithDocumentation.length - 1) { %>,<% } %>
  <%_ } _%>
            }
<%_ } _%>
        }
    }
<%_ if (microserviceAppName && !readOnly) { _%>,
    "<%- microserviceAppName %>": {
        "<%- entityTranslationKey %>" : {
            "created": "<%- Um %> <%- novo %> <%- entityNameHumanized %> foi <%- criado %> com o identificador {{ param }}",
            "updated": "<%- Um %> <%- entityNameHumanized %> foi <%- atualizado %> com o identificador {{ param }}",
            "deleted": "<%- Um %> <%- entityNameHumanized %> foi <%- excluido %> com o identificador {{ param }}"
        }
    }
<%_ } _%>
}
