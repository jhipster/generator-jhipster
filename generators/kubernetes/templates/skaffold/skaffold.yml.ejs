apiVersion: skaffold/v1
kind: Config
build:
  artifacts:
<%_ for (const appConfig of appConfigs) { _%>
  - image: <%- appConfig.targetImageName %>
    context: <%- `${directoryPath + appConfig.appFolder}` %>
    jib: {}
<%_ } _%>
  tagPolicy:
    envTemplate:
      template: "{{.IMAGE_NAME}}:latest"
deploy:
  kustomize: {}
