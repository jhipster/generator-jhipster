import { test, expect } from '@playwright/test';
import {
  accountMenuSelector,
  navbarSelector,
  loginItemSelector,
  getCredentials,
  login,
  clickOnLogoutItem,
} from '../../support/commands';

test.describe('logout', () => {
  let username: string;
  let password: string;

  test.beforeAll(() => {
    const credentials = getCredentials();
    username = credentials.username;
    password = credentials.password;
  });

  test('go to home page when successfully logs out', async ({ page }) => {
    await login(page, username, password);
    await page.goto('/');

    await clickOnLogoutItem(page);

<%_ if (authenticationUsesCsrf) { _%>
    // Wait for the logout API call to complete
    await page.waitForResponse(resp => resp.url().includes('/api/logout') && resp.request().method() === 'POST');
<%_ } _%>
    await page.locator(navbarSelector).locator(accountMenuSelector).click();
    await expect(page.locator(navbarSelector).locator(accountMenuSelector).locator(loginItemSelector)).toBeVisible();
  });
});
